{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/imagekit-auth", "destination": "/api/imagekit-auth" },
    { "source": "/api/config", "destination": "/api/config" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
